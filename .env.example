# ================================================
# متجر سعودي - ملف المتغيرات البيئية
# انسخ هذا الملف وأعد تسميته إلى .env
# ================================================

# ------------------------------------------------
# قاعدة البيانات PostgreSQL
# ------------------------------------------------
DATABASE_URL="postgresql://username:password@localhost:5432/saudi_store"

# ------------------------------------------------
# NextAuth - المصادقة والجلسات
# ------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production-min-32-chars"

# ------------------------------------------------
# بوابة دفع Moyasar - الأكثر شيوعاً في السعودية
# اشترك على: https://moyasar.com
# ------------------------------------------------
MOYASAR_SECRET_KEY="sk_test_xxxxxxxxxx"          # مفتاح الاختبار
MOYASAR_PUBLISHABLE_KEY="pk_test_xxxxxxxxxx"      # مفتاح النشر للاختبار
# للإنتاج استبدل test بـ live:
# MOYASAR_SECRET_KEY="sk_live_xxxxxxxxxx"
# MOYASAR_PUBLISHABLE_KEY="pk_live_xxxxxxxxxx"

# ------------------------------------------------
# بوابة دفع Tap Payments
# اشترك على: https://tap.company
# ------------------------------------------------
TAP_SECRET_KEY="sk_test_xxxxxxxxxx"
TAP_PUBLISHABLE_KEY="pk_test_xxxxxxxxxx"
# للإنتاج:
# TAP_SECRET_KEY="sk_live_xxxxxxxxxx"

# ------------------------------------------------
# بوابة دفع HyperPay
# اشترك على: https://www.hyperpay.com
# ------------------------------------------------
HYPERPAY_ACCESS_TOKEN="your-hyperpay-token"
HYPERPAY_ENTITY_ID_VISA="your-entity-id-visa-master"
HYPERPAY_ENTITY_ID_MADA="your-entity-id-mada"
HYPERPAY_BASE_URL="https://eu-test.oppwa.com"   # Sandbox
# للإنتاج:
# HYPERPAY_BASE_URL="https://oppwa.com"

# ------------------------------------------------
# شركة شحن Aramex
# اشترك على: https://www.aramex.com/developers
# ------------------------------------------------
ARAMEX_USERNAME="your-aramex-username"
ARAMEX_PASSWORD="your-aramex-password"
ARAMEX_ACCOUNT_NUMBER="your-account-number"
ARAMEX_ACCOUNT_PIN="your-account-pin"
ARAMEX_ACCOUNT_ENTITY="AMM"
ARAMEX_ACCOUNT_COUNTRY_CODE="SA"
ARAMEX_WSDL_URL="https://ws.aramex.net/ShippingAPI.V2/Shipping/Service_1_0.svc?wsdl"
# Sandbox URL:
# ARAMEX_WSDL_URL="https://ws.aramex.net/ShippingAPI.V2/Shipping/Service_1_0.svc?wsdl"

# ------------------------------------------------
# شركة شحن SMSA Express
# اشترك على: https://developer.smsa.com
# ------------------------------------------------
SMSA_API_KEY="your-smsa-api-key"
SMSA_PASSKEY="your-smsa-passkey"
SMSA_BASE_URL="https://track.smsaexpress.com/SECOM/SMSAwebService.asmx"
# Sandbox URL:
# SMSA_BASE_URL="https://staging-api.smsa.com"

# ------------------------------------------------
# البريد السعودي SPL (واصل)
# اشترك على: https://developer.spl.com.sa
# ------------------------------------------------
SPL_API_KEY="your-spl-api-key"
SPL_USERNAME="your-spl-username"
SPL_PASSWORD="your-spl-password"
SPL_BASE_URL="https://api.spl.com.sa/api"
SPL_ACCOUNT_NUMBER="your-account-number"

# ------------------------------------------------
# رفع الصور - Cloudinary أو S3
# اشترك على: https://cloudinary.com
# ------------------------------------------------
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# أو استخدم AWS S3:
# AWS_ACCESS_KEY_ID="your-key-id"
# AWS_SECRET_ACCESS_KEY="your-secret"
# AWS_REGION="me-south-1"
# AWS_BUCKET_NAME="your-bucket"

# ------------------------------------------------
# إعدادات البريد الإلكتروني (للإشعارات)
# ------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="متجرك <no-reply@yourstore.com>"

# ------------------------------------------------
# إعدادات عامة للمتجر
# ------------------------------------------------
NEXT_PUBLIC_STORE_NAME="متجر الخير"
NEXT_PUBLIC_STORE_PHONE="+966500000000"
NEXT_PUBLIC_WHATSAPP_NUMBER="966500000000"
NEXT_PUBLIC_STORE_ADDRESS="الرياض، المملكة العربية السعودية"

# ------------------------------------------------
# رمز الدخول لإنشاء الأدمن الأول (احذفه بعد الإنشاء)
# ------------------------------------------------
ADMIN_REGISTER_TOKEN="your-secret-admin-token-2024"
